# Copy from Neon dashboard → Connection string
# On Windows, the app auto-uses the direct host (drops -pooler) to avoid ENOTFOUND.
# Set USE_NEON_POOLER=true to force the pooled hostname from Neon.
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-PROJECT-pooler.REGION.aws.neon.tech/neondb?sslmode=require

JWT_SECRET=change-me-in-production
PORT=3000
USE_NEON_POOLER=

# Cloudinary — profile & image uploads (folder: TOBEDONE in media library)
# Dashboard: https://console.cloudinary.com → Settings → API Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=TOBEDONE

# Optional: Expo access token for push notifications (expo.dev → Account → Access Tokens)
EXPO_ACCESS_TOKEN=
