# Copy from Neon dashboard → Connection string
# On Windows, the app auto-uses the direct host (drops -pooler) to avoid ENOTFOUND.
# Set USE_NEON_POOLER=true to force the pooled hostname from Neon.
DATABASE_URL=postgresql://USER:PASSWORD@YOUR-PROJECT-pooler.REGION.aws.neon.tech/neondb?sslmode=require

JWT_SECRET=change-me-in-production
PORT=3000
USE_NEON_POOLER=
